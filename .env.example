OIDC_ISSUER=https://your-team.cloudflareaccess.com/cdn-cgi/access/sso/oidc/<app-id>
OIDC_CLIENT_ID=<app-id>
OIDC_CLIENT_SECRET=<secret>
OIDC_REDIRECT_URL=https://pages.arlint.dev/auth/callback
OIDC_SCOPES=openid profile email

# Pick exactly one of the two — without either, every sign-in is refused.

# Comma-separated allowlist. Only these emails can sign in.
# OIDC_ALLOWED_EMAILS=you@example.com,teammate@example.com

# Or: allow any IdP-verified email. Use with a tight policy at the IdP
# (e.g. Cloudflare Access policy that already restricts who can authenticate).
# OIDC_ALLOW_OPEN_SIGNUP=1
