OIDC_ISSUER=https://your-team.cloudflareaccess.com/cdn-cgi/access/sso/oidc/<app-id>
OIDC_CLIENT_ID=<app-id>
OIDC_CLIENT_SECRET=<secret>
OIDC_REDIRECT_URL=https://pages.arlint.dev/auth/callback
OIDC_SCOPES=openid profile email
# Optional comma-separated allowlist; empty = anyone the IdP authenticates.
# OIDC_ALLOWED_EMAILS=you@example.com
